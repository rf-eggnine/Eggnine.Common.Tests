<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local feed for packed-but-not-yet-published Eggnine.Common builds. Merges with the
         machine-wide nuget.org source (no <clear/> here), so PackageReferences that resolve
         from nuget.org (e.g. xunit) still work normally. -->
    <add key="eggnine-local" value="/home/rf/Eggnine/nuget-local" />
  </packageSources>
</configuration>
